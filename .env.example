# ──────────────────────────────────────────────────────
# nota. — Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# Nunca faça commit do arquivo .env preenchido.
# ──────────────────────────────────────────────────────

# Anthropic — obter em: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase — obter em: https://app.supabase.com → projeto → Settings → API
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Rate limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=3600000

# Porta do servidor (padrão: 3000)
# PORT=3000

# ──────────────────────────────────────────────────────
# Variáveis adicionais para o QA Test Suite
# ──────────────────────────────────────────────────────

# URL base da API (backend em execução local ou staging)
API_URL=http://localhost:3000

# Usuário de teste (deve ser pré-cadastrado no Supabase antes de rodar o suite)
# Criar via: POST /auth/register ou diretamente no painel Supabase
TEST_USER_EMAIL=teste@nota.app
TEST_USER_PASSWORD=SenhaForte123!

# Para habilitar testes RATE-02 e RATE-03, configure valores baixos:
# RATE_LIMIT_MAX=3
# RATE_LIMIT_WINDOW_MS=60000
